.DS_Store
__pycache__/
*.py[cod]

# Local environments and tool caches
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Scrape debug/research artifacts
debug_*.py
research_*.py
*_debug.png
debug_*.png
*.html
!tests/fixtures/*.html
screenshots/
tmp/*
!tmp/.gitkeep

# Generated news scrape outputs and ledgers
data/raw/news_VN_*.csv
data/raw/news_scrape_ledger.json
data/raw/urls_*.txt
!data/raw/.gitkeep

# Large raw datasets
data/vific/fine-tunes/ViFiC-120M/*
!data/vific/fine-tunes/ViFiC-120M/.gitkeep
data/vific/fine-tunes/ViFiC-93M/*
!data/vific/fine-tunes/ViFiC-93M/.gitkeep
data/archive.zip

# Processed data, models, and logs (ignore contents but keep structure)
data/interim/*
!data/interim/.gitkeep
data/sentiment/*
!data/sentiment/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/vific/processed/*
!data/vific/processed/.gitkeep
data/vific/annotation/*
!data/vific/annotation/.gitkeep
models/*
!models/.gitkeep
logs/*
!logs/.gitkeep


# Report Files
!report/.gitkeep
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.synctex.*
report/*.fdb_latexmk
report/*.fls
report/*.blg
report/*.bbl


# Environment Files
.env
.envrc

# VnCoreNLP local artifacts (downloaded JAR + models)
vncorenlp/*.jar
vncorenlp/models/
